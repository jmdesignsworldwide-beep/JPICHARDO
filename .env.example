# ─────────────────────────────────────────────────────────────
# Blessing House · Variables de entorno (Fort Knox)
# Copia este archivo a `.env.local` y rellena los valores reales.
# NUNCA subas `.env.local` al repositorio. NUNCA uses el prefijo
# NEXT_PUBLIC_ para credenciales — solo servidor.
# ─────────────────────────────────────────────────────────────

# --- Envío de correo del formulario de contacto (servidor) ---
# Interruptor maestro: el correo solo se envía si es "true" Y hay credencial.
CONTACT_EMAIL_ENABLED=false

# Proveedor SMTP/API. Ejemplo con SMTP genérico o un servicio como Resend.
# Estas variables SOLO se leen en el API Route server-side.
CONTACT_TO_EMAIL=blessinghousecchurch@gmail.com
CONTACT_FROM_EMAIL=

# Si usas un proveedor tipo Resend / Postmark / SendGrid:
EMAIL_API_KEY=

# Si usas SMTP directo:
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- (Opcional) reCAPTCHA v3 para el formulario ---
# La clave SECRETA nunca lleva NEXT_PUBLIC_. La site key pública sí puede.
RECAPTCHA_SECRET_KEY=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# --- Rate limiting distribuido (opcional, ej. Upstash Redis) ---
# Sin estas variables, el rate limit cae a un limitador en memoria por instancia.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
